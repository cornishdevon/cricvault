{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "5GM5VG9H5Z",
        "ascApiKeyId": { "env": "ASC_API_KEY_ID" },
        "ascApiKeyIssuerId": { "env": "ASC_API_KEY_ISSUER_ID" },
        "ascApiKeyPath": { "env": "ASC_API_KEY_PATH" }
      }
    }
  }
}
